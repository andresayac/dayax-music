# Server port
PORT=3512

# Allowed CORS origins (comma-separated)
# In production, set this to your frontend domain
ALLOWED_ORIGINS=http://localhost:3333,http://127.0.0.1:3333

# PoToken — Proof of Origin Token (anti-bot bypass for datacenter IPs)
# Generate on the server: npx youtube-po-token-generator
YOUTUBE_PO_TOKEN=

# Visitor data — persistent visitor ID (generated together with PoToken)
YOUTUBE_VISITOR_DATA=
