# Server port
PORT=3512

# Allowed CORS origins (comma-separated)
# In production, set this to your frontend domain
ALLOWED_ORIGINS=http://localhost:3333,http://127.0.0.1:3333

# YouTube cookie — required for streaming on servers/datacenter IPs.
# How to get it:
#   1. Open https://www.youtube.com in your browser (logged in)
#   2. DevTools (F12) → Application → Cookies → youtube.com
#   3. Copy ALL cookies as a single string: NAME1=VALUE1; NAME2=VALUE2; ...
#   Key cookies: SID, HSID, SSID, APISID, SAPISID, __Secure-1PSID, __Secure-3PSID
#   Or use a browser extension like "EditThisCookie" to export them.
YOUTUBE_COOKIE=

# (Optional) PoToken — Proof of Origin Token for extra anti-bot bypass.
# Generate with: npx youtube-po-token-generator
# YOUTUBE_PO_TOKEN=

# (Optional) Visitor data — persistent visitor ID.
# YOUTUBE_VISITOR_DATA=
